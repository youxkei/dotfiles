{
  "$schema": "https://schema.linearmouse.app/0.11.2",
  "schemes": [
    {
      "if": {
        "device": {
          "category": "mouse"
        }
      },
      "pointer": {
        "acceleration": 0.5,
        "speed": 0.8
      },
      "scrolling": {
        "reverse": {
          "vertical": true,
          "horizontal": true
        }
      }
    }
  ]
}
