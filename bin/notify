#!/bin/sh
# Usage: notify <title> <message>

title="${1:-Notification}"
message="${2:-}"

case "$(uname -s)" in
    Darwin)
        esc_title=$(printf '%s' "$title" | sed 's/\\/\\\\/g; s/"/\\"/g')
        esc_message=$(printf '%s' "$message" | sed 's/\\/\\\\/g; s/"/\\"/g')
        osascript -e "display notification \"$esc_message\" with title \"$esc_title\""
        ;;
    *)
        pwsh.exe -Command "New-BurntToastNotification -UniqueIdentifier 'notify' -Text '$title','$message'"
        ;;
esac
