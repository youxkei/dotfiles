#!/usr/bin/env zsh
# auto-komorebi: macOS equivalent of bin/auto-komorebi.ps1.
# Starts komorebi-for-mac with the CUE-generated config, runs the same
# "pile workspaces from disconnected logical monitors onto a primary
# connected monitor" reconciliation as the Windows komorebi.ps1, and
# re-runs that reconciliation whenever komorebi reports a display
# connection change via its subscription socket.

set -euo pipefail
# Inherited xtrace/verbose from .zshenv leaks variable assignments into stdout
# and interferes with `$(...)` captures; force it off for this script.
setopt no_xtrace no_verbose 2>/dev/null || true

REPO_DIR="${REPO_DIR:-$HOME/repo/dotfiles}"
CONFIG_DIR="$HOME/Library/Application Support/komorebi"
CONFIG="$REPO_DIR/komorebi/komorebi.mac.json"
SOCK_NAME="auto-komorebi.sock"
SOCK="$CONFIG_DIR/$SOCK_NAME"

PRIORITY_ORDER=(center left right)

configure_workspaces() {
    local monitor_info logical_monitors
    monitor_info=$(komorebic monitor-info)
    logical_monitors=$(make --no-print-directory -C "$REPO_DIR" komorebi-logical-monitors-mac)

    local connected_devices
    connected_devices=$(
        print -r -- "$monitor_info" \
            | jq -r '.[].serial_number_id
                | select(. != null and . != "" and (gsub("\\s"; "") != "0000000000000"))'
    )

    local lm connected=() disconnected=()
    for lm in "${PRIORITY_ORDER[@]}"; do
        local matched
        matched=$(
            print -r -- "$logical_monitors" \
                | jq --arg lm "$lm" --arg ids "$connected_devices" '
                    ($ids | split("\n") | map(select(length > 0))) as $cd
                    | .[$lm].device_ids
                    | any(. as $d | $cd | index($d) != null)
                '
        )
        if [[ "$matched" == "true" ]]; then
            connected+=("$lm")
        else
            disconnected+=("$lm")
        fi
    done

    if (( ${#disconnected[@]} == 0 )); then
        echo "[auto-komorebi] all logical monitors connected; no piling needed"
        register_workspace_rules
        return 0
    fi

    local primary primary_index workspaces=()
    if (( ${#connected[@]} == 0 )); then
        primary=""
        primary_index=0
        for lm in "${PRIORITY_ORDER[@]}"; do
            local ws
            ws=$(print -r -- "$logical_monitors" | jq -r --arg lm "$lm" '.[$lm].workspaces[]')
            workspaces+=(${(f)ws})
        done
        echo "[auto-komorebi] no known logical monitors connected; piling all workspaces onto monitor 0"
    else
        primary="${connected[1]}"
        local primary_device_ids
        primary_device_ids=$(
            print -r -- "$logical_monitors" | jq -r --arg lm "$primary" '.[$lm].device_ids[]'
        )
        primary_index=$(
            print -r -- "$monitor_info" \
                | jq --arg ids "$primary_device_ids" '
                    ($ids | split("\n") | map(select(length > 0))) as $pd
                    | to_entries
                    | map(select(.value.serial_number_id as $s | $pd | index($s) != null))
                    | .[0].key // -1
                '
        )
        if [[ "$primary_index" == "-1" ]]; then
            echo "[auto-komorebi] primary logical monitor '$primary' has no matching connected monitor; aborting reconciliation" >&2
            return 1
        fi

        local ws
        ws=$(print -r -- "$logical_monitors" | jq -r --arg lm "$primary" '.[$lm].workspaces[]')
        workspaces+=(${(f)ws})

        for lm in "${disconnected[@]}"; do
            ws=$(print -r -- "$logical_monitors" | jq -r --arg lm "$lm" '.[$lm].workspaces[]')
            workspaces+=(${(f)ws})
            echo "[auto-komorebi] $lm logical monitor not connected; piling workspaces onto $primary (monitor $primary_index): ${ws//$'\n'/, }"
        done
    fi

    komorebic ensure-named-workspaces "$primary_index" "${workspaces[@]}"
    register_workspace_rules
}

# Register initial-workspace-rules so that newly opened windows land on the
# right workspace. Workspace rules get reset when ensure-named-workspaces is
# called, so this must be re-applied on every reconciliation (mirrors
# bin/komorebi.ps1 on Windows).
register_workspace_rules() {
    komorebic initial-named-workspace-rule exe Chrome r0
    komorebic initial-named-workspace-rule exe Ghostty c0
    komorebic initial-named-workspace-rule exe Neovide c1
    komorebic initial-named-workspace-rule exe Slack l1
    komorebic initial-named-workspace-rule exe Claude r5
    # Rejysten is titleless; enforce_workspace_rules (window_manager.rs)
    # skips windows whose `window.title()` is None, so this rule never
    # actually applies. place_titleless_apps below handles the move.
    # Re-enable once upstream allows matching when title is None.
    # komorebic initial-named-workspace-rule exe Rejysten l0
    komorebic enforce-workspace-rules
}

# komorebi-for-mac's load_workspace_information (macos_api.rs) matches CGS
# window list entries to AX elements via window_by_title (application.rs).
# Apps whose CGS-reported title differs from their AX title get skipped at
# startup and never managed. Clicking such a window later triggers
# ShowOnInputEvent (input_event_listener.rs) which manages it correctly.
# Workaround: activate each running GUI app once and issue `komorebic manage`
# to force-trigger the Show/Manage handler for its main window. ignored apps
# are filtered out by should_manage (window.rs).
force_manage_running_apps() {
    # `name of process` returns the executable filename, which collapses Chrome
    # PWAs (Rejysten, etc.) onto a single "app_mode_loader" entry that doesn't
    # match the per-PWA process. `displayed name` matches what komorebi sees as
    # the application name, so resolve and activate by that.
    local original apps app
    original=$(osascript -e 'tell application "System Events" to get displayed name of first process whose frontmost is true' 2>/dev/null)
    apps=$(osascript <<'EOF' 2>/dev/null
tell application "System Events"
    set names to {}
    repeat with p in (every process whose background only is false)
        set end of names to displayed name of p
    end repeat
    return names
end tell
EOF
)

    local -a app_array
    IFS=$',\n' read -A app_array <<<"$apps"
    for app in "${app_array[@]}"; do
        app="${app## }"
        app="${app%% }"
        [[ -z "$app" ]] && continue
        osascript -e "tell application \"System Events\" to set frontmost of (first process whose displayed name is \"$app\") to true" 2>/dev/null || continue
        komorebic manage 2>/dev/null || true
    done

    if [[ -n "$original" ]]; then
        osascript -e "tell application \"System Events\" to set frontmost of (first process whose displayed name is \"$original\") to true" 2>/dev/null || true
    fi
}

# Workspace rules don't fire for titleless apps: enforce_workspace_rules
# (window_manager.rs) requires `Some(title)` from `window.title()` before
# matching, but Chrome PWAs in `titleless_applications` return None from
# kAXTitleAttribute. Manually activate each known titleless app and move
# it to its rule's workspace.
place_titleless_apps() {
    osascript -e 'tell application "System Events" to set frontmost of (first process whose displayed name is "Rejysten") to true' 2>/dev/null || return 0
    sleep 0.3
    komorebic move-to-named-workspace l0 2>/dev/null || true
}

cleanup() {
    if [[ -n "${KOMOREBI_PID:-}" ]]; then
        kill -INT "$KOMOREBI_PID" 2>/dev/null || true
    fi
    if [[ -n "${WAKE_LISTENER_PID:-}" ]]; then
        kill "$WAKE_LISTENER_PID" 2>/dev/null || true
    fi
    if [[ -n "${WAKE_READER_PID:-}" ]]; then
        kill "$WAKE_READER_PID" 2>/dev/null || true
    fi
    rm -f "$SOCK" "${WAKE_PIPE:-}"
}
trap cleanup EXIT INT TERM

echo "[auto-komorebi] regenerating $CONFIG from CUE"
make -C "$REPO_DIR" komorebi-mac >/dev/null

echo "[auto-komorebi] stopping any running komorebi"
komorebic stop --bar 2>/dev/null || true

# Bypass `komorebic start -c <path>`: it spawns the daemon with a broken
# `'--config="<path>"'` argument (komorebic/src/main.rs:1772 in komorebi-for-mac)
# which clap rejects. Invoke the daemon directly with the correct flag instead.
echo "[auto-komorebi] starting komorebi with $CONFIG"
komorebi --config "$CONFIG" >/dev/null 2>&1 &
KOMOREBI_PID=$!

for _ in $(seq 1 30); do
    if komorebic state >/dev/null 2>&1; then
        echo "[auto-komorebi] komorebi started (pid $KOMOREBI_PID)"
        break
    fi
    if ! kill -0 "$KOMOREBI_PID" 2>/dev/null; then
        echo "[auto-komorebi] komorebi daemon exited before becoming ready" >&2
        exit 1
    fi
    sleep 0.5
done

if ! komorebic state >/dev/null 2>&1; then
    echo "[auto-komorebi] komorebi did not become ready in time" >&2
    exit 1
fi

configure_workspaces || true
force_manage_running_apps
place_titleless_apps

mkdir -p "$CONFIG_DIR"
rm -f "$SOCK"

# Register the subscription once nc has had a chance to bind the socket.
( sleep 1
  echo "[auto-komorebi] subscribing to komorebi events via $SOCK_NAME"
  komorebic subscribe-socket "$SOCK_NAME"
) &

# The Swift helper drives pause/unpause directly via komorebi's socket so it
# can race the reaper effectively (komorebi/src/reaper.rs reaps managed
# windows whenever AX queries fail during display sleep — see the long
# comment in bin/komorebi-wake-listener for the rationale). The shell side
# only handles retile + logging once the helper signals that AX is back.
WAKE_PIPE="$CONFIG_DIR/auto-komorebi.wake"
rm -f "$WAKE_PIPE"
mkfifo "$WAKE_PIPE"

# Set KOMOREBI_WAKE_DEBUG=1 in the environment when launching auto-komorebi
# to get IOKit message timing dumped to stderr (visible in the terminal).
"$REPO_DIR/bin/komorebi-wake-listener" >"$WAKE_PIPE" &
WAKE_LISTENER_PID=$!

( while IFS= read -r line; do
    case "$line" in
        will-sleep)
            echo "[auto-komorebi] pre-sleep: komorebi paused"
            ;;
        wake)
            echo "[auto-komorebi] post-wake: komorebi unpaused; retiling"
            komorebic retile 2>/dev/null || true
            ;;
    esac
done <"$WAKE_PIPE" ) &
WAKE_READER_PID=$!

# nc -lkU keeps accepting new connections after each one closes, so a single
# invocation can sit there for the lifetime of the script. Stays in the
# foreground so Ctrl-C tears the whole pipeline down cleanly.
nc -lkU "$SOCK" | while IFS= read -r line; do
    case "$line" in
        *DisplayConnectionChange*)
            echo "[auto-komorebi] display connection change detected; reconfiguring workspaces"
            configure_workspaces || true
            ;;
    esac
done
